<?xml version='1.0'?>
<Obfuscator>
  <Var name="InPath" value=".\bin\Release\net9.0-windows\win-x64" />
  <Var name="OutPath" value=".\bin\Release\net9.0-windows\win-x64\Obfuscated" />
  <Var name="KeepPublicApi" value="true" />
  <Var name="HidePrivateApi" value="true" />
  <Var name="HideStrings" value="false" />
  <Var name="RenameProperties" value="false" />
  <Var name="RenameEvents" value="false" />
  <Var name="RenameFields" value="true" />

  <Module file="$(InPath)\TEMO.AI.dll">
    <SkipNamespace name="TEMO.AI.Models" />
    <SkipNamespace name="TEMO.AI.Views" />
    <SkipNamespace name="TEMO.AI.Ai" />
    <SkipNamespace name="TEMO.AI.Controls" />
    <SkipNamespace name="TEMO.AI.ViewModels" />
    <SkipType name="TEMO.AI.App" />
    <SkipType name="TEMO.AI.Program" />
    <SkipType name="TEMO.AI.MainWindow" />
    <SkipType name="TEMO.AI.LoginWindow" />
    <SkipType name="TEMO.AI.AppUpdateService" />
  </Module>

  <AssemblySearchPath path="$(InPath)" />
</Obfuscator>
