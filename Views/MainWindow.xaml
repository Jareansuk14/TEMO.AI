<Window x:Class="TEMO.AI.MainWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
       xmlns:local="clr-namespace:TEMO.AI"
       Title="TEMO.AI"
       Height="900" Width="1560"
       MinHeight="650" MinWidth="1100"
       Background="#0A0A0A"
       WindowStartupLocation="CenterScreen"
       FontFamily="Segoe UI"
       Icon="/Public/Logo.ico">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#111111" BorderBrush="#1E1E1E" BorderThickness="0,0,1,0">
            <DockPanel>

                <Border DockPanel.Dock="Top" Background="#0D0D0D"
                        BorderBrush="#1E1E1E" BorderThickness="0,0,0,1" Padding="20,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="BrandTitleText" Text="TEMO.AI" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF"/>
                            <TextBlock Text="Seo Generator" FontSize="11" Foreground="#3A3A3A" Margin="0,3,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="#3A3A3A" Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusText" Text="Offline" Foreground="#454545" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border DockPanel.Dock="Top" Background="#0E0E0E"
                        BorderBrush="#1E1E1E" BorderThickness="0,0,0,1" Padding="18,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="GenBtn" Content="⚡  สร้างเว็บอัตโนมัติ"
                                    Style="{StaticResource BtnAccent}"
                                    Grid.Column="0"
                                    Height="36" FontSize="12" Padding="0"
                                    Click="Gen_Click"/>
                            <Button x:Name="ApiKeyBtn" Content="🔑" Grid.Column="2"
                                    Style="{StaticResource Btn}"
                                    Width="38" Height="36" FontSize="15" Padding="0"
                                    ToolTip="API Key"
                                    Click="ApiKeyToggle_Click"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="New Project" Grid.Column="0"
                                    Style="{StaticResource BtnAccent}"
                                    Height="36" FontSize="12" Padding="0"
                                    Click="NewProject_Click"/>
                            <Grid Grid.Column="2" Width="108">
                                <Button Content="Load Project"
                                        Style="{StaticResource Btn}"
                                        Height="36" FontSize="12" Padding="0"
                                        Click="LoadOldProject_Click"/>
                                <Border x:Name="LoadProjectNewBadge" Visibility="Collapsed"
                                        Background="#E23B3B" CornerRadius="9"
                                        Padding="5,1" MinWidth="18" Height="17"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,-6,-6,0" IsHitTestVisible="False">
                                    <TextBlock Text="NEW" FontSize="9" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <Button x:Name="SaveTemplateBtn" Grid.Column="4"
                                    Style="{StaticResource Btn}"
                                    Height="36" Width="44" Padding="0"
                                    IsEnabled="False"
                                    ToolTip="บันทึก Template"
                                    Click="SaveTemplate_Click">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="Transparent"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2" StrokeLineJoin="Round"
                                              Data="M4 5 H16 L20 9 V20 H4 Z"/>
                                        <Path Fill="Transparent"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2" StrokeLineJoin="Round"
                                              Data="M8 5 V9 H15 V5 M7 20 V13 H17 V20"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                        <TextBox x:Name="FolderPathBox" Style="{StaticResource Input}"
                                 FontSize="18" FontWeight="Bold" Padding="9,8" IsReadOnly="True"
                                 Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ServerBtn" Content="▶  START" Grid.Column="0"
                                    Style="{StaticResource BtnAccent}"
                                    Height="36" FontSize="12" Padding="0"
                                    IsEnabled="False"
                                    Click="ToggleServer_Click"/>
                            <Button x:Name="BackNavBtn" Grid.Column="1" Style="{StaticResource Btn}"
                                    Width="36" Height="36" Margin="6,0,0,0" Padding="0"
                                    IsEnabled="False"
                                    ToolTip="ย้อนกลับ" Click="Back_Click">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="Transparent"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2.4" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Data="M15 5 L8 12 L15 19"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="ForwardNavBtn" Grid.Column="2" Style="{StaticResource Btn}"
                                    Width="36" Height="36" Margin="6,0,0,0" Padding="0"
                                    IsEnabled="False"
                                    ToolTip="ไปหน้า" Click="Forward_Click">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="Transparent"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="2.4" StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Data="M9 5 L16 12 L9 19"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                            <Button x:Name="RefreshNavBtn" Grid.Column="3" Style="{StaticResource Btn}"
                                    Width="36" Height="36" Margin="6,0,0,0" Padding="0"
                                    IsEnabled="False"
                                    ToolTip="รีเฟรช" Click="Refresh_Click">
                                <Viewbox Width="15" Height="15">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M17.65 6.35A7.95 7.95 0 0 0 12 4a8 8 0 1 0 7.75 10h-2.08A6 6 0 1 1 12 6c1.66 0 3.14.69 4.22 1.78L13 11h7V4z"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border x:Name="ActionBar" DockPanel.Dock="Top" Background="#0E0E0E"
                        BorderBrush="#1E1E1E" BorderThickness="0,0,0,1" Padding="18,10"
                        Opacity="0.35">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SaveAllBtn" Content="SAVE ALL"
                                Style="{StaticResource BtnAccent}"
                                Height="38" FontSize="12" Padding="0"
                                IsEnabled="False"
                                Click="SaveAll_Click"/>
                        <Button x:Name="DeployBtn" Content="DEPLOY" Grid.Column="2"
                                Style="{StaticResource Btn}"
                                Width="86" Height="38" FontSize="12" Padding="0"
                                IsEnabled="False"
                                Click="Deploy_Click"/>
                    </Grid>
                </Border>

                <Border x:Name="ApiKeyPanel" DockPanel.Dock="Top" Background="#0A0D0F"
                        BorderBrush="#1A2535" BorderThickness="0,0,0,1" Padding="18,10"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="OPENAI API KEY"
                                   FontSize="10" FontWeight="Bold"
                                   Foreground="#4A80B8" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AiKeyBox" Style="{StaticResource Input}"
                                     FontSize="12" Padding="9,7"/>
                            <Button Content="SAVE" Grid.Column="2"
                                    Style="{StaticResource BtnAccent}"
                                    Width="80" Height="36" FontSize="11" Padding="0"
                                    Click="ApiKeySave_Click"/>
                            <Button Content="✕" Grid.Column="4"
                                    Style="{StaticResource Btn}"
                                    Width="36" Height="36" FontSize="13" Padding="0"
                                    Click="ApiKeyClose_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Bottom" Background="#0D0D0D"
                        BorderBrush="#1E1E1E" BorderThickness="0,1,0,0" Padding="18,9">
                    <TextBlock x:Name="StatusLabel"
                               Text="Ready"
                               Foreground="#454545" FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>

                <TabControl x:Name="MainTabs" Background="Transparent" BorderThickness="0">

                    <TabItem Header="CONTENT">
                        <DockPanel>

                            <Border x:Name="ContentTabToolbar" DockPanel.Dock="Top"
                                    Background="#0E0E0E" BorderBrush="#1E1E1E"
                                    BorderThickness="0,0,0,1" Padding="14,7"
                                    IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="ContentAiToggleBtn" Style="{StaticResource Btn}"
                                            Height="32" Padding="12,0"
                                            Click="ContentAiToggle_Click">
                                        <TextBlock Text="Generate AI" VerticalAlignment="Center" FontSize="11"/>
                                    </Button>
                                    <Button x:Name="ContentUndoBtn"
                                            Style="{StaticResource Btn}" Height="32" Padding="12,0"
                                            Margin="5,0,0,0" IsEnabled="False"
                                            Click="UndoLastSave_Click"
                                            ToolTip="ย้อนกลับไปยัง save ก่อนหน้า">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="↩" FontSize="13" Margin="0,0,5,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="UNDO" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </Border>

                            <Border x:Name="ContentAiPanel" DockPanel.Dock="Top" Background="#090C10"
                                    BorderBrush="#1A2535" BorderThickness="0,0,0,1" Padding="18,12"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Content Generator"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#4A80B8"/>
                                        </StackPanel>
                                        <Button Content="✕" HorizontalAlignment="Right"
                                                Style="{StaticResource Btn}"
                                                Width="26" Height="26" FontSize="12" Padding="0"
                                                Click="ContentAiClose_Click"/>
                                    </Grid>
                                    <TextBlock Text="ประเภทเนื้อหา"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555555" Margin="0,0,0,6"/>
                                    <UniformGrid Rows="1" Columns="3">
                                        <RadioButton x:Name="ContentAiCasino"
                                                     Content="คาสิโน"
                                                     GroupName="ContentAiType"
                                                     IsChecked="True"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="ContentAiLottery"
                                                     Content="หวย"
                                                     GroupName="ContentAiType"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="ContentAiSlot"
                                                     Content="สล็อต"
                                                     GroupName="ContentAiType"
                                                     Style="{StaticResource BtnModel}"/>
                                    </UniformGrid>
                                    <TextBlock x:Name="ContentAiKwLabel"
                                               Text="Keyword เสริม (ไม่บังคับ • สูงสุด 3)"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555555" Margin="0,10,0,6"/>
                                    <Grid x:Name="ContentAiKwHost"/>
                                    <Button x:Name="ContentAiGenBtn" Content="✦  GEN"
                                            Style="{StaticResource BtnAccent}"
                                            Height="34" FontSize="12" Padding="0"
                                            Margin="0,8,0,0"
                                            Click="ContentAiGen_Click"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer x:Name="ContentScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          IsEnabled="False">
                                <StackPanel x:Name="ContentPanel" Margin="18,18,18,24" Opacity="0"/>
                            </ScrollViewer>

                        </DockPanel>
                    </TabItem>

                    <TabItem Header="LAYOUT">
                        <ScrollViewer x:Name="LayoutScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsEnabled="False">
                            <StackPanel x:Name="LayoutPanel" Margin="18,18,18,24" Opacity="0">
                                <StackPanel x:Name="ShellSectionWrap">
                                    <TextBlock Text="ส่วนหลัก (เปลี่ยนแบบได้)"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#AAAAAA" Margin="0,0,0,8"/>
                                    <ListBox x:Name="ShellList"
                                             Background="#0E0E0E"
                                             BorderBrush="#282828"
                                             BorderThickness="1"
                                             Margin="0,0,0,16"
                                             SelectionMode="Single">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Background" Value="#161616"/>
                                                <Setter Property="Foreground" Value="#DEDEDE"/>
                                                <Setter Property="BorderBrush" Value="#282828"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#1E1E1E"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Background="Transparent">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="12,10">
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="14"/>
                                                        <TextBlock Text="{Binding Variant}"
                                                                   FontSize="10"
                                                                   Foreground="#666666"
                                                                   Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="ShellChangeBorder"
                                                            Grid.Column="1"
                                                            Background="Transparent"
                                                            Padding="10"
                                                            Cursor="Hand"
                                                            MouseDown="ChangeShellVariant_MouseDown"
                                                            ToolTip="เปลี่ยนแบบ">
                                                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                            <Canvas Width="24" Height="24">
                                                                <Path x:Name="ShellChangeIcon"
                                                                      Stroke="#666666"
                                                                      StrokeThickness="2.4"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      StrokeLineJoin="Round"
                                                                      Data="M5 19 L8.8 18.2 L18.2 8.8 L15.2 5.8 L5.8 15.2 L5 19 M13.8 7.2 L16.8 10.2"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <Trigger SourceName="ShellChangeBorder" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ShellChangeIcon" Property="Stroke" Value="#FFFFFF"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>

                                <Grid x:Name="LayoutSectionHeader" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="จัดเรียง Section"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#AAAAAA"
                                                   Visibility="{x:Static local:MainWindow.DevEditVisibility}"/>
                                        <TextBlock Text="Section"
                                                   FontSize="13" FontWeight="Bold"
                                                   Foreground="#AAAAAA"
                                                   Visibility="{x:Static local:MainWindow.DevReadOnlyVisibility}"/>
                                    </StackPanel>
                                    <Button x:Name="AddSectionBtn"
                                            Grid.Column="1"
                                            Content="+ Add Section"
                                            Style="{StaticResource BtnAccent}"
                                            Height="34" Padding="12,0" FontSize="11"
                                            Click="AddLayoutSection_Click"/>
                                </Grid>
                                
                                <ListBox x:Name="LayoutList"
                                         Background="#0E0E0E"
                                         BorderBrush="#282828"
                                         BorderThickness="1"
                                         MinHeight="200"
                                         Margin="0,0,0,12"
                                         SelectionMode="Single">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Background" Value="#161616"/>
                                            <Setter Property="Foreground" Value="#DEDEDE"/>
                                            <Setter Property="BorderBrush" Value="#282828"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Cursor" Value="Hand"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}">
                                                            <ContentPresenter/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1E1E1E"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Margin="12,10">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               Visibility="{x:Static local:MainWindow.DevEditVisibility}"/>
                                                    <TextBlock Text="{Binding KindUpper}"
                                                               VerticalAlignment="Center"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Visibility="{x:Static local:MainWindow.DevReadOnlyVisibility}"/>
                                                    <TextBlock Text="{Binding Variant}"
                                                               FontSize="10"
                                                               Foreground="#666666"
                                                               Margin="0,3,0,0"
                                                               Visibility="{x:Static local:MainWindow.DevEditVisibility}"/>
                                                </StackPanel>
                                                <Border x:Name="SwapIconBorder"
                                                        Grid.Column="1"
                                                        Background="Transparent"
                                                        Padding="10"
                                                        Cursor="Hand"
                                                        MouseDown="SwapIcon_MouseDown">
                                                    <TextBlock x:Name="SwapIcon"
                                                               Text="⇄" 
                                                               FontSize="18"
                                                               Foreground="#666666"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ChangeIconBorder" 
                                                        Grid.Column="2"
                                                        Background="Transparent"
                                                        Padding="10"
                                                        Cursor="Hand"
                                                        Visibility="{x:Static local:MainWindow.DevEditVisibility}"
                                                        MouseDown="ChangeLayoutSection_MouseDown"
                                                        ToolTip="เปลี่ยนแบบ section">
                                                    <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                        <Canvas Width="24" Height="24">
                                                            <Path x:Name="ChangeIcon"
                                                                  Stroke="#666666"
                                                                  StrokeThickness="2.4"
                                                                  StrokeStartLineCap="Round"
                                                                  StrokeEndLineCap="Round"
                                                                  StrokeLineJoin="Round"
                                                                  Data="M5 19 L8.8 18.2 L18.2 8.8 L15.2 5.8 L5.8 15.2 L5 19 M13.8 7.2 L16.8 10.2"/>
                                                        </Canvas>
                                                    </Viewbox>
                                                </Border>
                                                <Grid Grid.Column="3" Visibility="{x:Static local:MainWindow.DevEditVisibility}">
                                                    <Border x:Name="DeleteIconBorder" 
                                                            Background="Transparent"
                                                            Padding="10"
                                                            Cursor="Hand"
                                                            MouseDown="DeleteLayoutSection_MouseDown"
                                                            ToolTip="ลบ section">
                                                        <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                                            <Canvas Width="24" Height="24">
                                                                <Path x:Name="DeleteIcon"
                                                                      Stroke="#7A3A3A"
                                                                      StrokeThickness="2.6"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      Data="M6 6 L18 18 M18 6 L6 18"/>
                                                            </Canvas>
                                                        </Viewbox>
                                                    </Border>
                                                </Grid>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="Selected">
                                                    <Setter TargetName="SwapIcon" Property="Foreground" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding CanRemove}" Value="False">
                                                    <Setter TargetName="DeleteIconBorder" Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <Trigger SourceName="SwapIconBorder" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="SwapIcon" Property="Foreground" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger SourceName="ChangeIconBorder" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ChangeIcon" Property="Stroke" Value="#FFFFFF"/>
                                                </Trigger>
                                                <Trigger SourceName="DeleteIconBorder" Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="DeleteIcon" Property="Stroke" Value="#E06A6A"/>
                                                </Trigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="CSS">
                        <DockPanel>

                            <Border x:Name="CssTabToolbar" DockPanel.Dock="Top"
                                    Background="#0E0E0E" BorderBrush="#1E1E1E"
                                    BorderThickness="0,0,0,1" Padding="14,7"
                                    IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource Btn}" Height="32" Padding="12,0"
                                            Click="CssAiToggle_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="Generate AI" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="CssUndoBtn"
                                            Style="{StaticResource Btn}" Height="32" Padding="12,0"
                                            Margin="5,0,0,0" IsEnabled="False"
                                            Click="UndoLastSave_Click"
                                            ToolTip="ย้อนกลับไปยัง save ก่อนหน้า">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="↩" FontSize="13" Margin="0,0,5,0"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text="UNDO" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Button>

                                </StackPanel>
                            </Border>

                            <Border x:Name="CssAiPanel" DockPanel.Dock="Top" Background="#090C10"
                                    BorderBrush="#1A2535" BorderThickness="0,0,0,1" Padding="18,12"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="CSS Generator"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#4A80B8"/>
                                        </StackPanel>
                                        <Button Content="✕" HorizontalAlignment="Right"
                                                Style="{StaticResource Btn}"
                                                Width="26" Height="26" FontSize="12" Padding="0"
                                                Click="CssAiClose_Click"/>
                                    </Grid>
                                    <TextBlock Text="MODEL"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555555" Margin="0,0,0,6"/>
                                    <UniformGrid Rows="1" Columns="3">
                                        <RadioButton x:Name="CssModelGpt55"
                                                     Content="GPT-5.5"
                                                     GroupName="CssAiModel"
                                                     IsChecked="True"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="CssModelGpt5"
                                                     Content="GPT-5"
                                                     GroupName="CssAiModel"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="CssModelGpt5Mini"
                                                     Content="GPT-5 mini"
                                                     GroupName="CssAiModel"
                                                     Style="{StaticResource BtnModel}"/>
                                    </UniformGrid>
                                    <Button x:Name="CssAiGenBtn" Content="✦  GEN"
                                            Style="{StaticResource BtnAccent}"
                                            Height="34" FontSize="12" Padding="0"
                                            Margin="0,8,0,0"
                                            Click="CssAiGen_Click"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer x:Name="CssScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          IsEnabled="False">
                                <StackPanel x:Name="CssPanel" Margin="18,18,18,24" Opacity="0">
                                    <TextBlock Text="CSS Variables (theme.css :root)"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#AAAAAA" Margin="0,0,0,16"/>
                                </StackPanel>
                            </ScrollViewer>

                        </DockPanel>
                    </TabItem>

                    <TabItem Header="IMG">
                        <DockPanel>

                            <Border x:Name="ImgTabToolbar" DockPanel.Dock="Top"
                                    Background="#0E0E0E" BorderBrush="#1E1E1E"
                                    BorderThickness="0,0,0,1" Padding="14,7"
                                    IsEnabled="False">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{StaticResource Btn}" Height="32" Padding="12,0"
                                            Click="ScrapeImages_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Viewbox Width="13" Height="13" Margin="0,0,6,0">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="Transparent"
                                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                          StrokeThickness="2" StrokeLineJoin="Round"
                                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                          Data="M3 11v8h18v-8M12 3v11M9 11l3 4 3-4"/>
                                                </Canvas>
                                            </Viewbox>
                                            <TextBlock Text="ดูดภาพ" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource Btn}" Height="32" Padding="12,0"
                                            Margin="8,0,0,0"
                                            Click="OpenOriginalImgPicker_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="เลือกจากรูปที่ดึงมา" VerticalAlignment="Center" FontSize="11"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="ImgAiToggleBtn" Style="{StaticResource Btn}" Height="32"
                                            Padding="12,0" Margin="8,0,0,0"
                                            Click="ImgAiToggle_Click">
                                        <TextBlock Text="Generate AI" VerticalAlignment="Center" FontSize="11"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <Border x:Name="ImgAiPanel" DockPanel.Dock="Top" Background="#090C10"
                                    BorderBrush="#1A2535" BorderThickness="0,0,0,1" Padding="18,12"
                                    Visibility="Collapsed">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Image + CSS Generator"
                                                       FontSize="11" FontWeight="Bold"
                                                       Foreground="#4A80B8"/>
                                        </StackPanel>
                                        <Button Content="✕" HorizontalAlignment="Right"
                                                Style="{StaticResource Btn}"
                                                Width="26" Height="26" FontSize="12" Padding="0"
                                                Click="ImgAiClose_Click"/>
                                    </Grid>
                                    <TextBlock Text="ประเภทเนื้อหา"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#555555" Margin="0,0,0,6"/>
                                    <UniformGrid Rows="1" Columns="3" Margin="0,0,0,10">
                                        <RadioButton x:Name="ImgAiCasino"
                                                     Content="คาสิโน"
                                                     GroupName="ImgAiType"
                                                     IsChecked="True"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="ImgAiLottery"
                                                     Content="หวย"
                                                     GroupName="ImgAiType"
                                                     Style="{StaticResource BtnModel}"
                                                     Margin="0,0,4,0"/>
                                        <RadioButton x:Name="ImgAiSlot"
                                                     Content="สล็อต"
                                                     GroupName="ImgAiType"
                                                     Style="{StaticResource BtnModel}"/>
                                    </UniformGrid>
                                    <Button x:Name="ImgAiGenBtn" Content="✦  GEN รูป + CSS"
                                            Style="{StaticResource BtnAccent}"
                                            Height="34" FontSize="12" Padding="0"
                                            Margin="0,8,0,0"
                                            Click="ImgAiGen_Click"/>
                                </StackPanel>
                            </Border>

                            <ScrollViewer x:Name="ImagesScroll"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          IsEnabled="False">
                                <StackPanel x:Name="ImagesPanel" Margin="18,18,18,24" Opacity="0"/>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>

                    <TabItem Header="SITE">
                        <ScrollViewer x:Name="SiteScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsEnabled="False">
                            <StackPanel x:Name="SitePanel" Margin="18,18,18,24" Opacity="0"/>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="KEYWORDS">
                        <ScrollViewer x:Name="KeywordsScroll"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      IsEnabled="False">
                            <StackPanel x:Name="KeywordsPanel" Margin="18,18,18,24" Opacity="0"/>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Background="#0A0A0A">
            <wv2:WebView2 x:Name="WebView" Visibility="Collapsed"/>
            <Border x:Name="LoadingOverlay" Background="#0D0D0D" Visibility="Visible" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="LoadingBrandText" Text="TEMO.AI" FontSize="44" FontWeight="Bold"
                               Foreground="#FFFFFF" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LoadingText" Text="Start server to preview"
                               Foreground="#404040" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="AiOverlay"
                Grid.Column="0"
                Panel.ZIndex="500"
                Background="#CC000000"
                Visibility="Collapsed">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">

                <StackPanel x:Name="AiOverlayLoading"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="AiOverlayStatusText"
                               Text="AI GENERATING..."
                               FontSize="24" FontWeight="Bold"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"
                               Margin="0,20,0,0"/>
                    <TextBlock Text="กรุณารอสักครู่ ห้ามปิดโปรแกรม"
                               FontSize="12" Foreground="#555555"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>

                <Border x:Name="AiOverlayError"
                        Background="#161616" BorderBrush="#2A2A2A"
                        BorderThickness="1" CornerRadius="6"
                        Padding="20,16" Width="340"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="⚠️  AI ตอบกลับไม่ตรงรูปแบบ"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="#FFAA44" Margin="0,0,0,4"/>
                        <TextBlock Text="ไม่พบ id= ที่ตรงกับ field — ข้อความที่ AI ตอบมา:"
                                   FontSize="10" Foreground="#555555"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBox x:Name="AiOverlayResponseBox"
                                 Style="{StaticResource Input}"
                                 Height="150" TextWrapping="Wrap"
                                 AcceptsReturn="True" FontSize="11"
                                 IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"/>
                        <Button Content="✓  OK"
                                Style="{StaticResource BtnAccent}"
                                Height="32" FontSize="12" Padding="0"
                                Margin="0,10,0,0"
                                Click="AiOverlayOk_Click"/>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

    </Grid>
</Window>
