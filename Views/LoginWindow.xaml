<Window x:Class="TEMO.AI.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TEMO.AI"
        Height="530" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0A0A0A"
        FontFamily="Segoe UI"
        Icon="/Public/Logo.ico">

    <Window.Resources>
        <Style x:Key="LoginFieldBorderStyle" TargetType="Border">
            <Setter Property="Height" Value="44"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#282828"/>
            <Setter Property="Background" Value="#161616"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
        <Style x:Key="LoginInnerTextStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#DEDEDE"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CaretBrush" Value="#4A80B8"/>
        </Style>
        <Style x:Key="LoginInnerPasswordStyle" TargetType="PasswordBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#DEDEDE"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Margin="32 40 32 40"
                Background="#111111" CornerRadius="8"
                BorderBrush="#1E1E1E" BorderThickness="1">
            <StackPanel Margin="36 32 36 32">

                <StackPanel HorizontalAlignment="Center" Margin="0 0 0 28">
                    <TextBlock x:Name="BrandTitleText" Text="TEMO.AI"
                               FontSize="28" FontWeight="Bold"
                               Foreground="#FFFFFF"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Username" FontSize="11" FontWeight="SemiBold"
                           Foreground="#4A80B8" Margin="0 0 0 6"/>
                <Border x:Name="UsernameBorder" Margin="0 0 0 16">
                    <Border.Style>
                        <Style BasedOn="{StaticResource LoginFieldBorderStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=TxtUsername}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3A6A9A"/>
                                    <Setter Property="Background" Value="#0D1A2A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="12,0">
                        <TextBox x:Name="TxtUsername" Style="{StaticResource LoginInnerTextStyle}"/>
                    </Grid>
                </Border>

                <TextBlock Text="Password" FontSize="11" FontWeight="SemiBold"
                           Foreground="#4A80B8" Margin="0 0 0 6"/>
                <Border x:Name="PasswordBorder" Margin="0 0 0 8">
                    <Border.Style>
                        <Style BasedOn="{StaticResource LoginFieldBorderStyle}" TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsKeyboardFocused, ElementName=TxtPassword}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3A6A9A"/>
                                    <Setter Property="Background" Value="#0D1A2A"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid Margin="12,0">
                        <PasswordBox x:Name="TxtPassword" Style="{StaticResource LoginInnerPasswordStyle}">
                            <PasswordBox.Template>
                                <ControlTemplate TargetType="PasswordBox">
                                    <Border Background="Transparent">
                                        <ScrollViewer x:Name="PART_ContentHost"
                                                      Focusable="False"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Stretch"
                                                      VerticalScrollBarVisibility="Hidden"
                                                      HorizontalScrollBarVisibility="Hidden"/>
                                    </Border>
                                </ControlTemplate>
                            </PasswordBox.Template>
                        </PasswordBox>
                    </Grid>
                </Border>

                <CheckBox x:Name="ChkRememberUsername" Margin="0 4 0 0"
                          FontSize="12" Foreground="#666666"
                          Content="Remember username and password"
                          VerticalContentAlignment="Center"/>

                <Border x:Name="ErrorBorder" CornerRadius="4" Padding="10 8"
                        Background="#2A1515" Margin="0 8 0 0"
                        BorderBrush="#3A2020" BorderThickness="1"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠ " FontSize="12" Foreground="#FF8888"
                                   VerticalAlignment="Center"/>
                        <Border x:Name="ErrorTextClip" Grid.Column="1"
                                ClipToBounds="True" VerticalAlignment="Center" Height="18">
                            <Canvas ClipToBounds="True">
                                <TextBlock x:Name="TxtError" FontSize="12" Foreground="#FF8888"
                                           Canvas.Top="1" TextWrapping="NoWrap"
                                           TextTrimming="None">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="TxtErrorTransform"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>
                        </Border>
                    </Grid>
                </Border>

                <Button x:Name="BtnLogin" Height="40" Margin="0 20 0 0"
                        Cursor="Hand" Click="BtnLogin_Click"
                        BorderThickness="1" BorderBrush="#CCCCCC"
                        Background="#E8E8E8" Foreground="#0A0A0A"
                        FontWeight="Bold" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">
                                        <VisualState x:Name="Normal"/>
                                        <VisualState x:Name="MouseOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="Bd"
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#FFFFFF" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="Bd"
                                                    Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                    To="#C0C0C0" Duration="0:0:0.05"/>
                                            </Storyboard>
                                        </VisualState>
                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                    To="0.4" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel x:Name="BtnContent" Orientation="Horizontal">
                        <Border x:Name="Spinner" Width="14" Height="14"
                                Margin="0 0 8 0" Visibility="Collapsed">
                            <Border.RenderTransform>
                                <RotateTransform CenterX="7" CenterY="7"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(Border.RenderTransform).(RotateTransform.Angle)"
                                                From="0" To="360" Duration="0:0:0.7"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Ellipse Stroke="#0A0A0A" StrokeThickness="2"
                                     Width="14" Height="14" Opacity="0.9"/>
                        </Border>
                        <TextBlock x:Name="BtnLabel" Text="Login"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#0A0A0A" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
